{
  "name": "liteloaderqqnt-i18n",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && bun run build.ts",
    "dev": "bun run build.ts --watch",
    "deploy": "tsc --noEmit && bun run build.ts && cp -r dist/src manifest.json res ~/.config/LiteLoaderQQNT/plugins/qq_i18n/"
  },
  "dependencies": {
    "i18next": "26.0.4",
    "idb-keyval": "6.2.2",
    "preact": "10.29.1",
    "preact-i18next": "11.8.5",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@types/bun": "1.3.12",
    "electron": "41.2.0",
    "postcss": "8.5.9",
    "postcss-load-config": "6.0.1",
    "tailwindcss": "4",
    "typescript": "6.0.2"
  }
}